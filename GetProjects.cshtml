@model List<UniversityManagementSystem.Models.EmpProjects>

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Project List</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
</head>
<body>
    <div class="container mt-4">
        <h2>Project Records</h2>
        <table id="projectTable" class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Emp ID</th>
                    <th>Name</th>
                    <th>Project Name</th>
                    <th>Due Date</th>
                    <th>Submission Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                    <tr data-id="@emp.p_id">
                        <td>@emp.e_id</td>
                        <td>@emp.FirstName @emp.LastName</td>
                        <td class="p_name">@emp.p_name</td>
                        <td class="duedate">@emp.duedate</td>
                        <td class="subdate">@emp.subdate</td>
                        <td class="p_status">@emp.p_status</td>
                        <td>
                            <button class="btn btn-sm btn-warning edit-btn">Edit</button>
                            <button class="btn btn-sm btn-success save-btn d-none">Save</button>
                            <button class="btn btn-sm btn-danger delete-btn">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#projectTable').DataTable();

            // Edit project row
            $(document).on('click', '.edit-btn', function () {
                var row = $(this).closest('tr');
                row.find('.p_name, .duedate, .subdate, .p_status').each(function () {
                    var value = $(this).text().trim();
                    $(this).html('<input type="text" class="form-control" value="' + value + '" />');
                });
                row.find('.edit-btn').addClass('d-none');
                row.find('.save-btn').removeClass('d-none');
            });

            // Save project row
            $(document).on('click', '.save-btn', function () {
                var row = $(this).closest('tr');
                var p_id = row.data('id');
                var e_id = row.find('td').eq(0).text().trim();
                var inputs = row.find('input');

                var data = {
                    p_id: p_id,
                    e_id: e_id,
                    p_name: inputs.eq(0).val(),
                    duedate: inputs.eq(1).val(),
                    subdate: inputs.eq(2).val(),
                    p_status: inputs.eq(3).val()
                };

                $.ajax({
                    url: '/Login/UpdateProject',
                    type: 'POST',
                    data: data,
                    success: function () {
                        row.find('.p_name').text(data.p_name);
                        row.find('.duedate').text(data.duedate);
                        row.find('.subdate').text(data.subdate);
                        row.find('.p_status').text(data.p_status);

                        row.find('.edit-btn').removeClass('d-none');
                        row.find('.save-btn').addClass('d-none');
                    }
                });
            });

            // Delete project row
            $(document).on('click', '.delete-btn', function () {
                var row = $(this).closest('tr');
                var p_id = row.data('id');

                if (confirm('Are you sure you want to delete this project?')) {
                    $.ajax({
                        url: '/Login/DeleteProject',
                        type: 'POST',
                        data: { p_id: p_id },
                        success: function () {
                            row.remove();
                        }
                    });
                }
            });
        });
    </script>
</body>
</html>
