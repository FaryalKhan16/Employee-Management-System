@model List<UniversityManagementSystem.Models.EmployeeWithSalary>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Employee Lists</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f4f7fc;
        }

        .sidebar {
            height: 100vh;
            background: #343a40;
            color: white;
            padding-top: 20px;
        }

            .sidebar a {
                color: white;
                display: block;
                padding: 12px 20px;
                text-decoration: none;
                transition: 0.3s;
            }

                .sidebar a:hover {
                    background: #17a2b8;
                    color: white;
                }

        .content {
            padding: 30px;
        }

        .table-container {
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 0 12px rgba(0,0,0,0.08);
        }

        .btn-custom {
            background-color: #007bff;
            color: white;
        }

            .btn-custom:hover {
                background-color: #0056b3;
            }
    </style>
</head>
<body>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 sidebar">
                <h4 class="text-center mb-4">Employees Lists</h4>
                <a href="/Login/AddProject"><i class="fas fa-home"></i> Add Project</a>
                <a href="/Login/GetEmployess"><i class="fas fa-users"></i> Employee List</a>
                <a href="/Login/Index"><i class="fas fa-chart-bar"></i> Dashboard</a>
                <a href="/Login/GetProjects"><i class="fas fa-chart-bar"></i> Projects List</a>
                <a href="/Login/AddLeave"><i class="fas fa-chart-bar"></i> Add Leave</a>
            </div>

            <!-- Content -->
            <div class="col-md-10 content">
                <div class="table-container">
                    <h3 class="mb-4">Employee Records</h3>
                    <table id="employeeTable" class="table table-bordered table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>Employee ID</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Contact</th>
                                <th>Department</th>
                                <th>Degree</th>
                                <th>Salary</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in Model)
                            {
                                <tr data-id="@emp.e_id">
                                    <td class="eid">@emp.e_id</td>
                                    <td class="name">@emp.FirstName @emp.LastName</td>
                                    <td class="email">@emp.Email</td>
                                    <td class="contact">@emp.Contact</td>
                                    <td class="department">@emp.Department</td>
                                    <td class="degree">@emp.Degree</td>
                                    <td class="salary">@emp.Total</td>
                                    <td>
                                        <button class="btn btn-sm btn-warning edit-btn">Edit</button>
                                        <button class="btn btn-sm btn-success save-btn d-none">Save</button>
                                        <button class="btn btn-sm btn-danger delete-btn">Delete</button>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>

                    <form asp-controller="Login" asp-action="AddEmployee" method="get">
                        <button type="submit" class="btn btn-custom mt-3">
                            <i class="fas fa-user-plus"></i> Add New Employee
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#employeeTable').DataTable({
                responsive: true
            });
        });



        //Update work here
            $(document).ready(function () {
            $('#employeeTable').DataTable();

            // Inline Edit
            $(document).on('click', '.edit-btn', function () {
                var row = $(this).closest('tr');
                row.find('td').each(function (index) {
                    if (index > 0 && index < 7) {
                        var value = $(this).text().trim();
                        $(this).html(`<input type="text" class="form-control" value="${value}" />`);
                    }
                });
                row.find('.edit-btn').addClass('d-none');
                row.find('.save-btn').removeClass('d-none');
            });

            // Save Edited Row
            $(document).on('click', '.save-btn', function () {
                var row = $(this).closest('tr');
                var e_id = row.data('id');
                var inputs = row.find('input');

                var updatedData = {
                    e_id: e_id,
                    FirstName: inputs.eq(0).val().split(' ')[0],
                    LastName: inputs.eq(0).val().split(' ')[1] || '',
                    Email: inputs.eq(1).val(),
                    Contact: inputs.eq(2).val(),
                    Department: inputs.eq(3).val(),
                    Degree: inputs.eq(4).val(),
                    Total: inputs.eq(5).val()
                };

                $.ajax({
                    url: '/Login/UpdateEmployee',
                    type: 'POST',
                    data: updatedData,
                    success: function () {
                        row.find('.name').html(`${updatedData.FirstName} ${updatedData.LastName}`);
                        row.find('.email').html(updatedData.Email);
                        row.find('.contact').html(updatedData.Contact);
                        row.find('.department').html(updatedData.Department);
                        row.find('.degree').html(updatedData.Degree);
                        row.find('.salary').html(updatedData.Total);

                        row.find('.edit-btn').removeClass('d-none');
                        row.find('.save-btn').addClass('d-none');
                    }
                });
            });

            // Delete Row
            $(document).on('click', '.delete-btn', function () {
                var row = $(this).closest('tr');
                var e_id = row.data('id');

                if (confirm("Are you sure you want to delete this record?")) {
                    $.ajax({
                        url: '/Login/DeleteEmployee',
                        type: 'POST',
                        data: { e_id: e_id },
                        success: function () {
                            row.remove();
                        }
                    });
                }
            });
        });

    </script>

</body>
</html>
