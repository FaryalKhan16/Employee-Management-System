
@{
    ViewData["Title"] = "Dashboard";
    Layout = null;
    var projectStatus = ((IEnumerable<dynamic>)ViewBag.ProjectStatus).Select(p => new { Status = (string)p.Status, Count = (int)p.Count }).ToList();
    var employeeStats = ((IEnumerable<dynamic>)ViewBag.EmployeeStats).Select(e => new { Department = (string)e.Department, Count = (int)e.Count }).ToList();
}

@using Newtonsoft.Json

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f4f7fc; /* same as second theme */
            margin: 0;
            min-height: 100vh;
            display: flex;
        }

        .sidebar {
            height: 100vh;
            width: 240px;
            background: #343a40; /* dark gray background */
            color: white;
            padding-top: 20px;
            position: fixed;
            top: 0;
            left: 0;
            overflow-y: auto;
        }

            .sidebar h4 {
                font-weight: bold;
                margin-bottom: 30px;
                color: white;
                text-align: center;
            }

            .sidebar a {
                color: white;
                display: block;
                padding: 12px 20px;
                text-decoration: none;
                transition: background 0.3s, color 0.3s;
            }

                .sidebar a:hover {
                    background: #17a2b8; /* cyan blue */
                    color: white;
                }

        .main-content {
            margin-left: 240px; /* leave space for sidebar */
            padding: 30px;
            flex: 1;
            background: #fff;
        }

        .card {
            border-radius: 12px;
            box-shadow: 0 0 10px rgba(0,0,0,0.08);
        }

        .chart-card {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 0 10px rgba(0,0,0,0.08);
            margin-bottom: 30px;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <h4>Dashboard</h4>
        <a href="/Login/AddProject"><i class="fas fa-home"></i> Add Project</a>
        <a href="/Login/GetEmployess"><i class="fas fa-users"></i> Employee List</a>
        <a href="/Login/Index"><i class="fas fa-chart-bar"></i> Dashboard</a>
        <a href="/Login/GetProjects"><i class="fas fa-chart-bar"></i> Projects List</a>
    </div>

    <div class="main-content">
        <h2 class="mb-4">Welcome to the Admin Dashboard</h2>

        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card bg-success text-white text-center p-4 shadow rounded">
                    <h4>Total Employees</h4>
                    <h2>@ViewBag.EmployeeCount</h2>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card bg-primary text-white text-center p-4 shadow rounded">
                    <h4>Total Projects</h4>
                    <h2>@ViewBag.ProjectCount</h2>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="chart-card">
                    <h5 class="text-center">Project Status</h5>
                    <canvas id="projectChart" height="250"></canvas>
                </div>
            </div>
            <div class="col-md-6">
                <div class="chart-card">
                    <h5 class="text-center">Employee Departments</h5>
                    <canvas id="employeeChart" height="250"></canvas>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Project Chart
        const projectCtx = document.getElementById('projectChart').getContext('2d');
        new Chart(projectCtx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(JsonConvert.SerializeObject(projectStatus.Select(p => p.Status))),
                datasets: [{
                    data: @Html.Raw(JsonConvert.SerializeObject(projectStatus.Select(p => p.Count))),
                    backgroundColor: ['#4caf50', '#2196f3', '#ff9800', '#f44336', '#9c27b0'],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });

        // Employee Chart
        const empCtx = document.getElementById('employeeChart').getContext('2d');
        new Chart(empCtx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(JsonConvert.SerializeObject(employeeStats.Select(e => e.Department))),
                datasets: [{
                    data: @Html.Raw(JsonConvert.SerializeObject(employeeStats.Select(e => e.Count))),
                    backgroundColor: ['#673ab7', '#e91e63', '#03a9f4', '#009688', '#ffc107'],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });
    </script>

</body>
</html>
